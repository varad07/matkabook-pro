# Copy this file to .env and fill in your values before running docker compose

# PostgreSQL password (used by postgres container AND backend)
DB_PASSWORD=postgres

# JWT signing secret — change this in production!
JWT_SECRET=matkabook_secret_key_2024

# Socket.IO URL the browser connects to.
# Must be the public address of your server (hostname or IP).
# Nginx proxies /socket.io/ to the backend internally.
# Examples:
#   Local:      http://localhost
#   VPS/cloud:  http://YOUR_SERVER_IP
VITE_SOCKET_URL=http://localhost
